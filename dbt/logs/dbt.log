  create view "db"."analytics_intermediate"."int_customer_orders__dbt_tmp"
    
    
  as (
    with orders as (
    select * from "db"."analytics_staging"."stg_orders"
),

customers as (
    select * from "db"."analytics_staging"."stg_customers"
)

select
    o.order_id,
    o.customer_id,
    c.company_name,
    c.country as customer_country,
    c.company_size,
    c.industry,

    o.total_amount,
    o.status,
    o.payment_method,
    o.order_day,
    o.created_at

from orders o
left join customers c
    on o.customer_id = c.customer_id
  );
[0m19:40:18.736508 [debug] [Thread-2 (]: Using postgres connection "model.ecommerce_analytics.int_customer_lifecycle"
[0m19:40:18.744280 [debug] [Thread-1 (]: Using postgres connection "model.ecommerce_analytics.dim_products"
[0m19:40:18.747591 [debug] [Thread-2 (]: On model.ecommerce_analytics.int_customer_lifecycle: /* {"app": "dbt", "dbt_version": "1.8.3", "profile_name": "api_bi_profile", "target_name": "dev", "node_id": "model.ecommerce_analytics.int_customer_lifecycle"} */

  create view "db"."analytics_intermediate"."int_customer_lifecycle__dbt_tmp"
    
    
  as (
    with orders as (
    select * from "db"."analytics_staging"."stg_orders"
),

customers as (
    select * from "db"."analytics_staging"."stg_customers"
),

agg as (
    select
        customer_id,
        count(*) as total_orders,
        sum(case when status = 'delivered' then total_amount else 0 end) as revenue,
        max(created_at) as last_order_date
    from orders
    group by 1
)

select
    c.customer_id,
    c.company_name,
    c.country,
    c.company_size,
    c.industry,
    c.signup_date,

    coalesce(a.total_orders, 0) as total_orders,
    coalesce(a.revenue, 0) as revenue,
    a.last_order_date,


    case
        when c.company_size = '500+' then 'enterprise'
        when c.company_size in ('201-500','51-200') then 'mid_market'
        else 'small_business'
    end as customer_segment,

    current_date - c.signup_date as customer_age_days,

    -- status logic
    case
        when c.is_churned then 'churned'
        when coalesce(a.total_orders,0) = 0 then 'inactive'
        else 'active'
    end as customer_status

from customers c
left join agg a
    on c.customer_id = a.customer_id
  );
