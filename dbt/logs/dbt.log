  create  table "db"."analytics_marts"."dim_customers__dbt_tmp"
  
  
    as
  
  (
    

with c as (
    select * from "db"."analytics_staging"."stg_customers"
),

lifecycle as (
    select * from "db"."analytics_intermediate"."int_customer_lifecycle"
)

select
    c.customer_id,
    c.company_name,
    c.country,
    c.industry,
    c.company_size,
    c.signup_month,

    l.customer_status,
    l.customer_segment,
    l.customer_age_days,
    l.revenue,
    l.total_orders

from c
left join lifecycle l
    on c.customer_id = l.customer_id
  );
  
