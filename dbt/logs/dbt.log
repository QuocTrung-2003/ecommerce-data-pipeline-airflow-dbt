[0m18:43:33.765702 [debug] [Thread-1 (]: On model.ecommerce_analytics.int_orders: /* {"app": "dbt", "dbt_version": "1.8.3", "profile_name": "api_bi_profile", "target_name": "dev", "node_id": "model.ecommerce_analytics.int_orders"} */

    
  
    

  create temporary table "int_orders__dbt_tmp184333747420"
  
  
    as
  
  (
    

with src as (
    select * from "db"."analytics_staging"."stg_orders"
),

cleaned as (
    select
        order_id,
        customer_id,

        -- numeric safety
        total_amount::numeric as total_amount,

        -- normalize text
        lower(trim(status)) as status,
        lower(trim(payment_method)) as payment_method,
        upper(trim(country)) as country,

        created_at::timestamp as created_at,
        updated_at::timestamp as updated_at,

        -- derived column
        date_trunc('day', created_at)::date as order_day

    from src
),

valid as (
    select *
    from cleaned
    where order_id is not null
      and customer_id is not null
      and total_amount is not null
      and updated_at is not null
),

final as (
    select *
    from valid

    
    where updated_at > (
        select coalesce(max(updated_at), '1900-01-01')
        from "db"."analytics_intermediate"."int_orders"
    )
    
)

select * from final
  );
  
  
